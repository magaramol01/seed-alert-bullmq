# Redis / BullMQ connection for the seed-alert producer.
# Keep these in sync with the defect-identification-service so both point at the same queue.
REDIS_URL=redis://sshuser:adminssh@localhost:9326
BULLMQ_PREFIX=bull
DEFECT_QUEUE_NAME=defectIdentificationQueue

# Path to the CSV of alerts to seed (relative to this directory or absolute).
CSV_PATH=data.csv
